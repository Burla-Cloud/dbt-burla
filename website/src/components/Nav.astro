---
import { withBase } from "../utils/url";

const { pathname } = Astro.url;
const isActive = (p: string) => pathname === withBase(p) || pathname.startsWith(withBase(p));
---

<nav class="topnav">
  <div class="topnav-inner">
    <a class="topnav-brand" href={withBase("/")}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4Zm-9 9h7v7H4v-7Zm9 0h7v7h-7v-7Z" fill="currentColor"/>
        </svg>
      </span>
      <span class="brand-text">
        <span class="dim">dbt</span><span>-burla</span>
      </span>
    </a>
    <ul class="topnav-links">
      <li>
        <a href={withBase("/docs/quickstart/")} class={isActive("/docs/quickstart") ? "active" : ""}>
          Quickstart
        </a>
      </li>
      <li>
        <a href={withBase("/docs/")} class={isActive("/docs") && !isActive("/docs/quickstart") ? "active" : ""}>
          Docs
        </a>
      </li>
      <li>
        <a href={withBase("/examples/")} class={isActive("/examples") ? "active" : ""}>
          Examples
        </a>
      </li>
    </ul>
    <div class="topnav-right">
      <a class="topnav-gh" href="https://github.com/Burla-Cloud/dbt-burla" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.73.5.67 5.57.67 11.85c0 5.02 3.24 9.28 7.74 10.78.57.1.78-.25.78-.55v-1.94c-3.15.68-3.81-1.52-3.81-1.52-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.68.08-.68 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.22 3.27.93.1-.73.39-1.22.71-1.5-2.52-.29-5.17-1.26-5.17-5.6 0-1.24.44-2.25 1.16-3.04-.12-.29-.5-1.44.11-3 0 0 .95-.3 3.11 1.16a10.8 10.8 0 0 1 5.66 0c2.15-1.46 3.1-1.16 3.1-1.16.61 1.56.23 2.71.11 3 .72.79 1.16 1.8 1.16 3.04 0 4.35-2.66 5.3-5.19 5.58.4.35.76 1.04.76 2.1v3.11c0 .3.2.66.79.55 4.5-1.5 7.74-5.76 7.74-10.78C23.33 5.57 18.27.5 12 .5Z"/>
        </svg>
      </a>
      <a class="topnav-cta" href={withBase("/docs/quickstart/")}>Get started</a>
    </div>
  </div>
</nav>
