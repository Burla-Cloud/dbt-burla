---
// SVG data-flow diagram that replaces the old ASCII art.
---

<div class="arch-wrapper">
  <svg class="arch-diagram" viewBox="0 0 900 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="dbt-burla architecture diagram">
    <defs>
      <linearGradient id="adapter-bg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1a1d24" />
        <stop offset="100%" stop-color="#121317" />
      </linearGradient>
      <linearGradient id="wh-bg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#17232a" />
        <stop offset="100%" stop-color="#0f171c" />
      </linearGradient>
      <linearGradient id="burla-bg" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#2a1608" />
        <stop offset="100%" stop-color="#17100a" />
      </linearGradient>
      <marker id="arrowAccent" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#ff7a33" />
      </marker>
      <marker id="arrowSlate" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#5c7d8a" />
      </marker>
    </defs>

    <!-- Top: dbt CLI -->
    <g>
      <rect x="375" y="20" width="150" height="44" rx="10" fill="#1a1d24" stroke="#2b2e37" />
      <text x="450" y="45" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="14" font-weight="600">dbt run</text>
      <text x="450" y="59" text-anchor="middle" fill="#70747f" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">CLI</text>
    </g>
    <line x1="450" y1="64" x2="450" y2="94" stroke="#2b2e37" stroke-width="1.5" marker-end="url(#arrowSlate)" />

    <!-- Adapter -->
    <g>
      <rect x="220" y="100" width="460" height="100" rx="14" fill="url(#adapter-bg)" stroke="#2b2e37" />
      <text x="450" y="126" text-anchor="middle" fill="#ff7a33" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="11" letter-spacing="1.5">BURLAXXXADAPTER</text>
      <text x="450" y="148" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="15" font-weight="600">Subclass of your warehouse adapter</text>
      <text x="450" y="169" text-anchor="middle" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="12">dbt-duckdb · dbt-snowflake · dbt-bigquery</text>
      <text x="450" y="186" text-anchor="middle" fill="#70747f" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">Inherits every SQL feature — relations, materializations, incremental, snapshots</text>
    </g>

    <!-- Split labels -->
    <text x="310" y="225" text-anchor="middle" fill="#70747f" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="10" letter-spacing="1.5">SQL MODELS</text>
    <text x="590" y="225" text-anchor="middle" fill="#70747f" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="10" letter-spacing="1.5">PYTHON MODELS</text>

    <!-- Lines to children -->
    <line x1="310" y1="200" x2="310" y2="250" stroke="#5c7d8a" stroke-width="1.5" marker-end="url(#arrowSlate)" />
    <line x1="590" y1="200" x2="590" y2="250" stroke="#ff7a33" stroke-width="1.5" marker-end="url(#arrowAccent)" />

    <!-- Warehouse box -->
    <g>
      <rect x="205" y="258" width="210" height="96" rx="12" fill="url(#wh-bg)" stroke="#2b3b44" />
      <text x="310" y="284" text-anchor="middle" fill="#5c7d8a" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="10" letter-spacing="1.5">WAREHOUSE</text>
      <text x="310" y="306" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="14" font-weight="600">Runs SQL as usual</text>
      <text x="310" y="326" text-anchor="middle" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">DuckDB · Snowflake · BigQuery</text>
      <text x="310" y="343" text-anchor="middle" fill="#70747f" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">Unchanged from dbt-core</text>
    </g>

    <!-- BurlaPythonJobHelper -->
    <g>
      <rect x="485" y="258" width="210" height="96" rx="12" fill="url(#burla-bg)" stroke="#703a1b" />
      <text x="590" y="284" text-anchor="middle" fill="#ff7a33" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="10" letter-spacing="1.5">PYTHON JOB HELPER</text>
      <text x="590" y="306" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="13" font-weight="600">1 · Read upstream</text>
      <text x="590" y="324" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="13" font-weight="600">2 · Submit to Burla</text>
      <text x="590" y="342" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="13" font-weight="600">3 · Write result</text>
    </g>

    <!-- Burla cluster on the right -->
    <g>
      <rect x="735" y="258" width="150" height="96" rx="12" fill="#1a1d24" stroke="#2b2e37" />
      <text x="810" y="284" text-anchor="middle" fill="#ff7a33" font-family="JetBrainsMonoVariable, JetBrains Mono, ui-monospace, monospace" font-size="10" letter-spacing="1.5">BURLA CLUSTER</text>
      <text x="810" y="308" text-anchor="middle" fill="#f2f3f5" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="14" font-weight="600">up to 10k VMs</text>
      <text x="810" y="326" text-anchor="middle" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">remote_parallel_map</text>
      <text x="810" y="343" text-anchor="middle" fill="#70747f" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">in under 1 second</text>
    </g>

    <!-- Helper ↔ warehouse (read/write) -->
    <path d="M 485 290 C 450 290 450 300 415 300" stroke="#ff7a33" stroke-width="1.5" stroke-dasharray="4 3" fill="none" marker-end="url(#arrowAccent)" />
    <path d="M 415 330 C 450 330 450 340 485 340" stroke="#ff7a33" stroke-width="1.5" stroke-dasharray="4 3" fill="none" marker-end="url(#arrowAccent)" />

    <!-- Helper ↔ cluster -->
    <line x1="695" y1="306" x2="735" y2="306" stroke="#ff7a33" stroke-width="1.5" marker-end="url(#arrowAccent)" />
    <path d="M 735 330 L 695 330" stroke="#ff7a33" stroke-width="1.5" stroke-dasharray="4 3" fill="none" marker-end="url(#arrowAccent)" />

    <!-- Legend at the bottom -->
    <g transform="translate(220, 380)">
      <line x1="0" y1="0" x2="28" y2="0" stroke="#ff7a33" stroke-width="1.5" />
      <text x="36" y="4" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">Python path</text>

      <line x1="135" y1="0" x2="163" y2="0" stroke="#ff7a33" stroke-width="1.5" stroke-dasharray="4 3" />
      <text x="170" y="4" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">DataFrame transfer</text>

      <line x1="300" y1="0" x2="328" y2="0" stroke="#5c7d8a" stroke-width="1.5" />
      <text x="336" y="4" fill="#a8acb6" font-family="InterVariable, Inter, system-ui, sans-serif" font-size="11">SQL path</text>
    </g>
  </svg>
</div>
