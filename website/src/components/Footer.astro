---
import { withBase } from "../utils/url";
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href={withBase("/")} style="display: inline-flex; align-items: center; gap: 0.55rem; color: var(--text); font-weight: 600; letter-spacing: -0.02em;">
          <span class="brand-mark" aria-hidden="true" style="width: 1.5rem; height: 1.5rem; border-radius: 0.35rem;">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 0.9rem; height: 0.9rem;">
              <path d="M4 4h7v7H4V4Zm9 0h7v7h-7V4Zm-9 9h7v7H4v-7Zm9 0h7v7h-7v-7Z" fill="currentColor"/>
            </svg>
          </span>
          <span><span style="color: var(--text-dim); font-weight: 500;">dbt</span>-burla</span>
        </a>
        <p class="footer-tag">
          A dbt adapter that runs Python models on a Burla cluster.
          Made by the <a href="https://burla.dev">Burla</a> team.
        </p>
      </div>
      <ul class="footer-links">
        <li class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href={withBase("/docs/quickstart/")}>Quickstart</a></li>
            <li><a href={withBase("/docs/how-it-works/")}>How it works</a></li>
            <li><a href={withBase("/docs/configuration/")}>Configuration</a></li>
            <li><a href={withBase("/examples/")}>Examples</a></li>
          </ul>
        </li>
        <li class="footer-col">
          <h4>Warehouses</h4>
          <ul>
            <li><a href={withBase("/warehouses/duckdb/")}>DuckDB</a></li>
            <li><a href={withBase("/warehouses/snowflake/")}>Snowflake</a></li>
            <li><a href={withBase("/warehouses/bigquery/")}>BigQuery</a></li>
          </ul>
        </li>
        <li class="footer-col">
          <h4>Links</h4>
          <ul>
            <li><a href="https://github.com/Burla-Cloud/dbt-burla">GitHub</a></li>
            <li><a href="https://pypi.org/project/dbt-burla/">PyPI</a></li>
            <li><a href="https://burla.dev">Burla</a></li>
            <li><a href="https://cal.com/jakez/burla">Schedule a call</a></li>
          </ul>
        </li>
      </ul>
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Burla · FSL-1.1-Apache-2.0</span>
      <span>
        <a href="https://github.com/Burla-Cloud/dbt-burla/issues">Report an issue</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/Burla-Cloud/dbt-burla/blob/main/CHANGELOG.md">Changelog</a>
      </span>
    </div>
  </div>
</footer>
