---
import "../styles/docs.css";
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import { withBase } from "../utils/url";

interface PagerLink {
  title: string;
  href: string;
}

interface Crumb {
  title: string;
  href: string;
}

interface TocItem {
  id: string;
  title: string;
  level?: 2 | 3;
}

interface Props {
  title: string;
  description?: string;
  lede?: string;
  prev?: PagerLink;
  next?: PagerLink;
  crumbs?: Crumb[];
  toc?: TocItem[];
}

const { title, description, lede, prev, next, crumbs, toc } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="docs-shell">
    <div class="docs-layout">
      <Sidebar />

      <main class="docs-main">
        {crumbs && crumbs.length > 0 && (
          <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href={withBase("/")}>Home</a>
            {crumbs.map((c) => (
              <>
                <span class="sep">/</span>
                <a href={c.href}>{c.title}</a>
              </>
            ))}
            <span class="sep">/</span>
            <span>{title}</span>
          </nav>
        )}

        <div class="docs-title-wrap">
          <h1>{title}</h1>
          {lede && <p class="lede">{lede}</p>}
        </div>

        <article class="docs-content">
          <slot />
        </article>

        {(prev || next) && (
          <nav class="docs-footer" aria-label="Pager">
            {prev ? (
              <a class="docs-pager" href={prev.href}>
                <small>← Previous</small>
                <strong>{prev.title}</strong>
              </a>
            ) : (
              <span class="docs-pager-empty"></span>
            )}
            {next ? (
              <a class="docs-pager docs-pager--next" href={next.href}>
                <small>Next →</small>
                <strong>{next.title}</strong>
              </a>
            ) : (
              <span class="docs-pager-empty"></span>
            )}
          </nav>
        )}
      </main>

      {toc && toc.length > 0 && <Toc items={toc} />}
    </div>
  </div>
</BaseLayout>
