---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import "../styles/landing.css";
import { withBase } from "../utils/url";
import { Code } from "astro:components";

// ───────── Hero code: realistic, runnable LLM enrichment model ─────────
const heroCode = `import pandas as pd
from burla import remote_parallel_map
from openai import OpenAI


def classify(row: dict) -> dict:
    """Runs on one Burla worker, for one row."""
    client = OpenAI()
    response = client.chat.completions.create(
        model="gpt-4o-mini",
        messages=[{"role": "user", "content": f"Category: {row['subject']}"}],
    )
    row["category"] = response.choices[0].message.content.strip()
    return row


def model(dbt, session):
    dbt.config(
        materialized="table",
        burla_workers=200,                # 200 parallel API calls
        burla_cpus_per_worker=1,
    )
    tickets = dbt.ref("stg_support_tickets").to_dict("records")
    enriched = list(remote_parallel_map(classify, tickets))
    return pd.DataFrame(enriched)`;

// ───────── Before / after code ─────────
const snowparkCode = `# Snowpark - requires a live Snowflake warehouse for compute
# Cold start: ~30s. Each call: serialized to Snowflake.
def classify(row):
    # Snowpark has no OpenAI lib baked in.
    # You'd have to wrap it as a Python stored procedure
    # with imported packages, and the size/versions are
    # limited by what Snowflake supports.
    ...

def main(session):
    df = session.table("stg_support_tickets").to_pandas()
    df["category"] = df["subject"].apply(classify)   # serial
    session.write_pandas(df, "CATEGORIZED_TICKETS")`;

const burlaCode = `# dbt-burla - runs Python where Python runs best
# Cold start: <1s. Each call: its own worker, in parallel.
from burla import remote_parallel_map
from openai import OpenAI

def classify(row):
    client = OpenAI()  # any Python package, any version
    ...
    return row

def model(dbt, session):
    dbt.config(burla_workers=200)
    tickets = dbt.ref("stg_support_tickets").to_dict("records")
    return pd.DataFrame(remote_parallel_map(classify, tickets))`;

// ───────── Features ─────────
const features = [
  {
    icon: "bolt",
    title: "No cluster to manage",
    body: "Burla gives you elastic compute as a function call. Workers start in under a second — no Snowpark session, no Databricks cluster, no Dataproc template to wrestle with.",
  },
  {
    icon: "check-circle",
    title: "Every dbt feature still works",
    body: "dbt-burla subclasses your warehouse adapter. Lineage, ref(), tests, docs, incremental models, is_incremental, and snapshots all work unchanged.",
  },
  {
    icon: "docker",
    title: "Any Docker image, any hardware",
    body: "Per-model CPU, RAM, and GPU. Bake your own image with your exact dependencies, or use defaults. Every Python model can have its own shape.",
  },
  {
    icon: "wind",
    title: "Zero-setup local dev",
    body: "burla_fake: true runs Python models in-process. Perfect for local development, unit tests, and CI — no cluster, no credentials.",
  },
  {
    icon: "database",
    title: "Bring your warehouse",
    body: "First-class support for DuckDB, Snowflake, and BigQuery. SQL runs in your warehouse; only Python is routed to Burla.",
  },
  {
    icon: "shield",
    title: "Production ready",
    body: "mypy --strict, 97% test coverage, CI on Python 3.11 / 3.12 / 3.13, real integration tests against every warehouse, semantic versioning.",
  },
];

// ───────── Comparison ─────────
const compareRows = [
  ["No Spark / JVM cluster to manage", [true, true, false, false]],
  ["Sub-second worker startup", [true, false, false, false]],
  ["Scales to 1,000+ VMs in one call", [true, false, false, false]],
  ["Per-model CPU / RAM / GPU shape", [true, false, true, true]],
  ["Any Docker image", [true, false, true, true]],
  ["Runs locally with no cloud", [true, false, false, false]],
  ["Works with DuckDB", [true, false, false, false]],
  ["Works with Snowflake", [true, true, false, false]],
  ["Works with BigQuery", [true, false, true, false]],
  ["Distributed joins / shuffles", [false, true, true, true]],
  ["Snowflake-native Python UDFs", [false, true, false, false]],
] as const;

// ───────── Examples ─────────
const examples = [
  {
    tag: "DuckDB",
    title: "Quickstart",
    body: "Zero-setup, self-contained DuckDB project. No cloud, no cluster, no credentials. Runs in seconds.",
    href: "/examples/quickstart-duckdb/",
  },
  {
    tag: "Snowflake",
    title: "ML scoring",
    body: "Fan out ML inference to 500 workers over a Snowflake table. Results land back in Snowflake.",
    href: "/examples/snowflake-ml-scoring/",
  },
  {
    tag: "BigQuery",
    title: "LLM enrichment",
    body: "Per-row LLM API calls across a BigQuery dataset with rate-limit-friendly worker counts.",
    href: "/examples/bigquery-llm-enrichment/",
  },
  {
    tag: "Advanced",
    title: "Heavy compute fan-out",
    body: "remote_parallel_map inside a Python model for massive per-row parallelism.",
    href: "/examples/heavy-compute-fanout/",
  },
];

// ───────── FAQ ─────────
const faqs = [
  {
    q: "Does this replace dbt-snowflake / dbt-bigquery?",
    a: "No — dbt-burla inherits from those adapters. Everything they support still works. Only Python models are routed to Burla; SQL models run in your warehouse exactly as before.",
  },
  {
    q: "What about very large upstream tables?",
    a: "Python models pull the upstream table through pandas on the dbt-running machine. For tables under ~1M rows this is fine. For larger tables, aggregate or sample in SQL first so the Python model gets a manageable input — this is a dbt best practice regardless.",
  },
  {
    q: "Can I use GPUs?",
    a: "Yes. Burla supports GPUs per-function. Set <code>burla_image</code> to a CUDA image and request a GPU-shape worker via your Burla cluster config.",
  },
  {
    q: "How is this different from dbt-fal?",
    a: "dbt-fal was a general Python-orchestration adapter (now archived). dbt-burla is specifically designed to run Python on a Burla cluster — with sub-second worker startup, any Docker image, and dbt-native subclassing of your warehouse adapter.",
  },
  {
    q: "What if I don't have a Burla cluster yet?",
    a: "Set <code>burla_fake: true</code> and Python models run in-process. You can build and test your entire pipeline locally before provisioning anything. When you're ready, <code>burla login</code> and flip the flag.",
  },
  {
    q: "Is this production ready?",
    a: "v0.x — the API may change before v1.0. Core functionality is covered by 97% test coverage and real integration tests against every warehouse. Pin an exact version in production and follow the changelog.",
  },
  {
    q: "Does it support dbt Fusion?",
    a: "Not yet. Fusion's Rust engine has a different extension story; it's tracked for a future release. Today dbt-burla targets dbt-core 1.8 and 1.9.",
  },
];
---

<BaseLayout
  title="dbt-burla"
  description="Run dbt Python models on a Burla cluster — no Snowpark, no Dataproc, no Databricks. Scale to 1,000 VMs in 1 second."
>
  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="hero">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow">
          <span class="dot"></span>
          <span class="label">v0.1.0</span>
          <span class="divider"></span>
          <span>Now on PyPI</span>
        </div>

        <h1 class="hero-title">
          <span class="grad">Python in dbt,<br />without Spark.</span>
        </h1>

        <p class="hero-sub">
          <strong>dbt-burla</strong> is a dbt adapter that runs Python models on a
          <a href="https://burla.dev">Burla</a> cluster instead of Snowpark, Dataproc, or
          Databricks. Scale to 1,000 parallel workers in under a second — while your SQL
          keeps running in your warehouse.
        </p>

        <div class="hero-actions">
          <a class="btn btn--primary" href={withBase("/docs/quickstart/")}>
            Get started
            <Icon name="arrow-right" />
          </a>
          <a class="btn btn--secondary" href={withBase("/docs/how-it-works/")}>How it works</a>
        </div>

        <div class="hero-install">
          <span class="prompt">$</span>
          <span>pip install "dbt-burla[duckdb]"</span>
          <button class="copy" onclick="navigator.clipboard?.writeText('pip install &quot;dbt-burla[duckdb]&quot;')" aria-label="Copy install command">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15V5a2 2 0 0 1 2-2h10" />
            </svg>
          </button>
        </div>

        <div class="hero-meta">
          <span class="badge">
            <Icon name="check" />
            DuckDB · Snowflake · BigQuery
          </span>
          <span class="badge">
            <Icon name="check" />
            dbt-core 1.8 / 1.9
          </span>
        </div>
      </div>

      <div class="hero-code">
        <div class="hero-code-window">
          <div class="hero-code-chrome">
            <span class="dots"><span></span><span></span><span></span></span>
            <span class="file">models/categorized_tickets.py</span>
            <span class="chip">Python · dbt</span>
          </div>
          <Code code={heroCode} lang="python" theme="github-light" />
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Logos strip ───────────────────────── -->
  <section class="logos-strip">
    <div class="logos-strip-inner">
      <span class="label">Works with</span>
      <span class="pill">DuckDB</span>
      <span class="pill">Snowflake</span>
      <span class="pill">BigQuery</span>
      <span class="label">Tested on</span>
      <span class="pill">Python 3.11 · 3.12 · 3.13</span>
      <span class="pill">dbt-core 1.8 / 1.9</span>
    </div>
  </section>

  <!-- ───────────────────────── PROBLEM ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">The problem</div>
      <h2>dbt's Python support is gated behind Spark.</h2>
      <p class="section-lede">
        Every path assumes you want JVM-based distributed DataFrames. But most Python work in a dbt
        DAG is embarrassingly parallel per-row — ML scoring, LLM enrichment, API calls, feature
        engineering. That doesn't need a Spark cluster. It needs a lot of Python processes.
      </p>
    </div>

    <div class="problem">
      <ol class="problem-options">
        <li>
          <span class="num">01</span>
          <span><strong>Snowpark</strong> — runs as a Snowflake stored procedure. Expensive compute, no custom images, no GPUs, limited package support.</span>
        </li>
        <li>
          <span class="num">02</span>
          <span><strong>Dataproc</strong> — managed Google Cloud Spark. Minutes of startup per model. Cluster configuration to maintain.</span>
        </li>
        <li>
          <span class="num">03</span>
          <span><strong>Databricks</strong> — a Spark cluster you provision. Separate bill, separate platform, separate permissions model.</span>
        </li>
      </ol>

      <div>
        <div class="problem-pull">
          <p>
            "A 500-VM fan-out for an LLM enrichment model shouldn't require standing up a Spark
            cluster."
          </p>
          <span class="attribution">— Every data engineer shipping Python in dbt</span>
        </div>
        <p style="color: var(--text-muted);">
          Either you stop using dbt for that step (losing lineage) or you accept the cost and setup
          overhead of Spark for work that doesn't benefit from it. <strong>dbt-burla</strong> is
          the third option.
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── WHY ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">Why dbt-burla</div>
      <h2>Elastic Python compute, no Spark required.</h2>
      <p class="section-lede">
        Every dbt feature still works. Every Python model has its own hardware. Local dev runs
        in-process with zero setup.
      </p>
    </div>

    <div class="feature-grid">
      {features.map((f) => (
        <div class="feature">
          <div class="feature-icon">
            <Icon name={f.icon as any} />
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── BEFORE / AFTER ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">Before / after</div>
      <h2>Same dbt project. Python that finally fits.</h2>
      <p class="section-lede">
        Same workload — classify 10,000 support tickets with an LLM, write the result back to the
        warehouse. dbt-burla makes the Python code shorter, faster, and trivial to run locally.
      </p>
    </div>

    <div class="beforeafter">
      <div class="ba-card">
        <div class="ba-head">
          <span class="ba-title">Snowpark</span>
          <span class="ba-tag ba-tag--bad">before</span>
        </div>
        <div class="ba-body">
          <Code code={snowparkCode} lang="python" theme="github-light" />
        </div>
        <div class="ba-notes">
          <strong>~30s</strong> cold start · Serial execution · Limited to Snowflake's package registry · Test loop hits Snowflake
        </div>
      </div>

      <div class="ba-card">
        <div class="ba-head">
          <span class="ba-title">dbt-burla</span>
          <span class="ba-tag ba-tag--good">after</span>
        </div>
        <div class="ba-body">
          <Code code={burlaCode} lang="python" theme="github-light" />
        </div>
        <div class="ba-notes">
          <strong>&lt;1s</strong> cold start · 200-way parallel · Any Python package · <code>burla_fake: true</code> for local dev
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── COMPARISON ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">vs the alternatives</div>
      <h2>Designed for per-row Python, not Spark workloads.</h2>
      <p class="section-lede">
        dbt-burla isn't trying to replace Spark for distributed joins. It's optimized for the
        per-row Python work you already do in dbt Python models — fast, cheap, without a cluster.
      </p>
    </div>

    <div class="compare-card">
      <table>
        <thead>
          <tr>
            <th></th>
            <th class="us">dbt-burla</th>
            <th>Snowpark</th>
            <th>Dataproc</th>
            <th>Databricks</th>
          </tr>
        </thead>
        <tbody>
          {compareRows.map(([label, values]) => (
            <tr>
              <td>{label}</td>
              {(values as readonly boolean[]).map((v, i) => (
                <td class={`${v ? "yes" : "no"}${i === 0 ? " us" : ""}`}>{v ? "✓" : "—"}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ───────────────────────── EXAMPLES ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">Runnable examples</div>
      <h2>Four reference projects, from zero-setup to massive fan-out.</h2>
      <p class="section-lede">
        Every example is a complete dbt project you can clone and run. Start with the DuckDB
        quickstart — no cloud, no cluster required.
      </p>
    </div>

    <div class="examples-grid">
      {examples.map((ex) => (
        <a class="ex-card" href={withBase(ex.href)}>
          <span class="tag">{ex.tag}</span>
          <h3>{ex.title}</h3>
          <p>{ex.body}</p>
          <span class="arrow">Read the guide →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── FAQ ───────────────────────── -->
  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">FAQ</div>
      <h2>Common questions.</h2>
      <p class="section-lede">Couldn't find what you're looking for? <a href="https://github.com/Burla-Cloud/dbt-burla/issues">Open an issue</a>.</p>
    </div>

    <div class="faq">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <div class="answer" set:html={`<p>${f.a}</p>`} />
        </details>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── CTA ───────────────────────── -->
  <section class="cta-section">
    <h2>Ready to run Python in dbt without Spark?</h2>
    <p>One <code>pip install</code>, one line in your profile. No cluster to configure.</p>
    <div class="cta-actions">
      <a class="btn btn--primary" href={withBase("/docs/quickstart/")}>
        Get started in 60 seconds
        <Icon name="arrow-right" />
      </a>
      <a class="btn btn--secondary" href="https://github.com/Burla-Cloud/dbt-burla">
        Star on GitHub
      </a>
    </div>
  </section>
</BaseLayout>
