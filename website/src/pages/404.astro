---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/url";
---

<BaseLayout title="Page not found" description="We couldn't find that page.">
  <div
    style="min-height: 60vh; display: grid; place-items: center; text-align: center; padding: 4rem 1.5rem;"
  >
    <div style="max-width: 36rem;">
      <div style="font-family: var(--font-mono); color: var(--accent); font-size: 5rem; font-weight: 700; letter-spacing: -0.05em;">404</div>
      <h1 style="margin-bottom: 1rem;">Page not found</h1>
      <p style="color: var(--text-muted); margin-bottom: 2rem;">
        The page you're looking for doesn't exist — we probably moved something around.
      </p>
      <div style="display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
        <a class="btn btn--primary" href={withBase("/")}>Go home</a>
        <a class="btn btn--secondary" href={withBase("/docs/quickstart/")}>Read the quickstart</a>
      </div>
    </div>
  </div>
</BaseLayout>
