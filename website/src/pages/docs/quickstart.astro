const toc = [
  { id: "option-a", title: "Zero-setup (DuckDB)", level: 2 as const },
  { id: "option-b", title: "Real cluster + warehouse", level: 2 as const },
  { id: "step-1", title: "1. Install", level: 3 as const },
  { id: "step-2", title: "2. Configure Burla", level: 3 as const },
  { id: "step-3", title: "3. Point profiles.yml", level: 3 as const },
  { id: "step-4", title: "4. Write a model", level: 3 as const },
