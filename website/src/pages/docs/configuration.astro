---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { Code } from "astro:components";
import { withBase } from "../../utils/url";

const toc = [
  { id: "profile", title: "Profile-level", level: 2 as const },
  { id: "profile-example", title: "Example (Snowflake)", level: 3 as const },
  { id: "model", title: "Model-level overrides", level: 2 as const },
  { id: "model-example", title: "Example", level: 3 as const },
  { id: "materializations", title: "Materializations", level: 2 as const },
  { id: "envvars", title: "Environment variables", level: 2 as const },
];
---

<DocsLayout
  title="Configuration reference"
  description="Every burla_* knob, at profile and model level."
  lede="Every burla_* knob, where to set it, what it does, and how profile-level defaults interact with per-model overrides. Model-level config wins."
  crumbs={[{ title: "Docs", href: withBase("/docs/") }]}
  toc={toc}
  prev={{ title: "How it works", href: withBase("/docs/how-it-works/") }}
  next={{ title: "Troubleshooting", href: withBase("/docs/troubleshooting/") }}
>
  <h2 id="profile">Profile-level (defaults for every Python model)</h2>
  <p>Set these inside your <code>outputs.&lt;target&gt;</code> block in <code>profiles.yml</code>.</p>

  <table>
    <thead>
      <tr><th>Key</th><th>Type</th><th>Default</th><th>Purpose</th></tr>
    </thead>
    <tbody>
      <tr><td><code>burla_cluster_url</code></td><td>str</td><td><em>uses <code>burla login</code></em></td><td>Override the cluster URL.</td></tr>
      <tr><td><code>burla_default_workers</code></td><td>int</td><td><code>16</code></td><td>Max concurrent workers per model.</td></tr>
      <tr><td><code>burla_default_cpus_per_worker</code></td><td>int</td><td><code>1</code></td><td>CPUs per worker VM.</td></tr>
      <tr><td><code>burla_default_ram_per_worker</code></td><td>int</td><td><code>None</code></td><td>RAM (GB) per worker VM.</td></tr>
      <tr><td><code>burla_default_image</code></td><td>str</td><td><code>None</code></td><td>Custom Docker image.</td></tr>
      <tr><td><code>burla_default_timeout_s</code></td><td>int</td><td><code>3600</code></td><td>Per-model timeout in seconds.</td></tr>
      <tr><td><code>burla_fake</code></td><td>bool</td><td><code>false</code></td><td>Run Python models in-process.</td></tr>
    </tbody>
  </table>

  <p>All other profile fields your warehouse adapter supports (<code>dbt-snowflake</code>, <code>dbt-bigquery</code>, <code>dbt-duckdb</code>) still work — dbt-burla is a subclass.</p>

  <h3 id="profile-example">Example (Snowflake)</h3>
  <Code code={`my_project:
  target: prod
  outputs:
    prod:
      type: burla_snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      database: PROD
      warehouse: PROD_WH
      schema: analytics
      threads: 8
      # Burla:
      burla_cluster_url: https://cluster.burla.dev
      burla_default_workers: 200
      burla_default_cpus_per_worker: 4
      burla_default_image: us-docker.pkg.dev/my-proj/worker:latest`} lang="yaml" theme="github-dark-dimmed" />

  <h2 id="model">Model-level (per-model overrides)</h2>
  <p>Set inside the Python model via <code>dbt.config(...)</code> or in a YAML config block.</p>

  <table>
    <thead>
      <tr><th>Key</th><th>Type</th><th>Default</th><th>Purpose</th></tr>
    </thead>
    <tbody>
      <tr><td><code>burla_workers</code></td><td>int</td><td>from profile</td><td>Override concurrent workers.</td></tr>
      <tr><td><code>burla_cpus_per_worker</code></td><td>int</td><td>from profile</td><td>CPUs per worker.</td></tr>
      <tr><td><code>burla_ram_per_worker</code></td><td>int</td><td>from profile</td><td>RAM (GB) per worker.</td></tr>
      <tr><td><code>burla_image</code></td><td>str</td><td>from profile</td><td>Override worker image.</td></tr>
      <tr><td><code>burla_timeout_s</code></td><td>int</td><td>from profile</td><td>Per-model timeout.</td></tr>
      <tr><td><code>burla_fake</code></td><td>bool</td><td>from profile</td><td>Override fake-mode.</td></tr>
    </tbody>
  </table>

  <h3 id="model-example">Example</h3>
  <Code code={`def model(dbt, session):
    dbt.config(
        materialized="table",
        burla_workers=500,
        burla_cpus_per_worker=2,
        burla_image="us-docker.pkg.dev/my-proj/heavy-worker:latest",
    )
    ...`} lang="python" theme="github-dark-dimmed" />

  <p>Or via YAML:</p>
  <Code code={`version: 2
models:
  - name: scored_customers
    config:
      materialized: table
      burla_workers: 500
      burla_cpus_per_worker: 2`} lang="yaml" theme="github-dark-dimmed" />

  <h2 id="materializations">Supported materializations</h2>

  <table>
    <thead>
      <tr><th>Materialization</th><th>Python</th><th>SQL</th><th>Notes</th></tr>
    </thead>
    <tbody>
      <tr><td><code>table</code></td><td>✓</td><td>✓</td><td>Writes replace the target atomically.</td></tr>
      <tr><td><code>incremental</code></td><td>✓</td><td>✓</td><td>Python returns a DataFrame of <em>new</em> rows; dbt-burla appends.</td></tr>
      <tr><td><code>view</code></td><td>—</td><td>✓</td><td>Not meaningful for Python (dbt-core limitation).</td></tr>
    </tbody>
  </table>

  <h2 id="envvars">Environment variables used</h2>
  <ul>
    <li><code>BURLA_CLUSTER_DASHBOARD_URL</code> — set from <code>burla_cluster_url</code>.</li>
    <li>Standard dbt / warehouse env vars (<code>SNOWFLAKE_*</code>, <code>BIGQUERY_PROJECT</code>, etc.) honored.</li>
  </ul>
</DocsLayout>
